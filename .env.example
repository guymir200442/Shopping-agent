# ============================================
# סוכן הקניות המשפחתי — משתני סביבה
# ============================================

# מפתח API של Anthropic (Claude)
# קבל מ: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# מספרי הטלפון של בני המשפחה (עם קידומת מדינה, מופרדים בפסיק)
# דוגמה: +972501234567,+972521234567
ALLOWED_NUMBERS=+972501234567,+972521234567

# פורט השרת (Railway מגדיר את זה אוטומטית)
PORT=3000
